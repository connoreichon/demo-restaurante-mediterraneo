---
import '../styles/global.css';
import { site } from '../data/site';
import { asset } from '../lib/asset';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.nombre} · ${site.reclamo} en ${site.ciudad.split(' ').slice(1).join(' ')}`,
  description = site.subtituloHero
} = Astro.props;

// URL absoluta para compartir en redes (requiere `site` en astro.config)
const ogImage = new URL(asset('/assets/img/hero-terraza-mar.jpg'), Astro.site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={asset('/assets/logo.svg')} />

    <!-- Tipografías (licencia abierta, sin derechos) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&family=Caveat:wght@500;600;700&display=swap"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#17130d" />

    <!-- Open Graph / redes -->
    <meta property="og:type" content="restaurant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Datos estructurados (mejora SEO local). Adapta a cada cliente. -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Restaurant',
        name: site.nombre,
        servesCuisine: 'Mediterránea',
        priceRange: '€€',
        telephone: site.telefono,
        address: {
          '@type': 'PostalAddress',
          streetAddress: site.direccion,
          addressLocality: site.ciudad
        }
      })}
    />
  </head>
  <body>
    <slot />

    <script>
      // Revela secciones al entrar en viewport (sin librerías)
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
