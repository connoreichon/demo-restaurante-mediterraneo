---
import { galeria } from '../data/site';
import { asset } from '../lib/asset';
---

<section id="galeria" class="bg-crema-200 py-20 md:py-28">
  <div class="container-x">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-terracota">El ambiente</p>
      <h2 class="font-display text-4xl text-carbon md:text-5xl">Un sitio para quedarse</h2>
    </div>

    <div class="mt-12 grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
      {
        galeria.map((g) => (
          <figure
            class:list={[
              'reveal overflow-hidden rounded-xl bg-carbon/5',
              g.alto ? 'row-span-2' : ''
            ]}
          >
            <img
              src={asset(g.src)}
              alt={g.alt}
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-700 hover:scale-105"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>
