---
import { site } from '../data/site';
import { asset } from '../lib/asset';
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
---

<section id="contacto" class="relative overflow-hidden bg-carbon py-20 text-crema md:py-28">
  <img
    src={asset('/assets/galeria-02.svg')}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover opacity-20"
  />
  <div class="absolute inset-0 bg-carbon/70"></div>

  <div class="container-x relative grid gap-12 lg:grid-cols-2">
    <div class="reveal">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-arena">Reservas y contacto</p>
      <h2 class="font-display text-4xl text-crema md:text-5xl">Te guardamos sitio</h2>
      <p class="mt-4 max-w-md text-crema/80">
        Escríbenos para reservar, organizar una comida de grupo o resolver cualquier duda. Te
        respondemos lo antes posible.
      </p>

      <ul class="mt-8 space-y-4 text-crema/90">
        <li class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-full bg-crema/10">📞</span>
          <a href={`tel:${site.telefono.replace(/\s/g, '')}`} class="hover:text-arena">{site.telefono}</a>
        </li>
        <li class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-full bg-crema/10">✉️</span>
          <a href={`mailto:${site.email}`} class="hover:text-arena">{site.email}</a>
        </li>
        <li class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-full bg-crema/10">📍</span>
          <span>{site.direccion}, {site.ciudad}</span>
        </li>
      </ul>

      <a
        href={waLink}
        target="_blank"
        rel="noopener"
        class="mt-8 inline-flex rounded-full bg-terracota px-7 py-3.5 font-semibold text-crema shadow-soft transition-transform hover:-translate-y-0.5 hover:bg-terracota-400"
      >
        Reservar por WhatsApp
      </a>
    </div>

    <!-- Formulario (demo: no envía a ningún sitio; en producción se conecta a email/servicio) -->
    <form
      class="reveal rounded-2xl bg-crema p-6 text-carbon shadow-soft md:p-8"
      onsubmit="event.preventDefault(); this.querySelector('[data-ok]').classList.remove('hidden'); this.reset();"
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium">Nombre</span>
          <input
            required
            type="text"
            name="nombre"
            class="mt-1 w-full rounded-lg border border-carbon/15 bg-white px-3 py-2.5 outline-none focus:border-terracota focus:ring-2 focus:ring-terracota/20"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Teléfono</span>
          <input
            required
            type="tel"
            name="telefono"
            class="mt-1 w-full rounded-lg border border-carbon/15 bg-white px-3 py-2.5 outline-none focus:border-terracota focus:ring-2 focus:ring-terracota/20"
          />
        </label>
      </div>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium">Fecha</span>
          <input
            type="date"
            name="fecha"
            class="mt-1 w-full rounded-lg border border-carbon/15 bg-white px-3 py-2.5 outline-none focus:border-terracota focus:ring-2 focus:ring-terracota/20"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Comensales</span>
          <input
            type="number"
            name="comensales"
            min="1"
            max="20"
            value="2"
            class="mt-1 w-full rounded-lg border border-carbon/15 bg-white px-3 py-2.5 outline-none focus:border-terracota focus:ring-2 focus:ring-terracota/20"
          />
        </label>
      </div>
      <label class="mt-4 block">
        <span class="text-sm font-medium">Mensaje (opcional)</span>
        <textarea
          name="mensaje"
          rows="3"
          class="mt-1 w-full rounded-lg border border-carbon/15 bg-white px-3 py-2.5 outline-none focus:border-terracota focus:ring-2 focus:ring-terracota/20"
        ></textarea>
      </label>
      <button
        type="submit"
        class="mt-5 w-full rounded-full bg-carbon px-6 py-3.5 font-semibold text-crema transition-colors hover:bg-carbon-700"
      >
        Solicitar reserva
      </button>
      <p data-ok class="mt-3 hidden rounded-lg bg-oliva/15 px-4 py-3 text-center text-sm text-oliva">
        ✓ ¡Gracias! (Demo) En la web real recibirías esta solicitud por email o WhatsApp.
      </p>
    </form>
  </div>
</section>
