---
import { opiniones, site } from '../data/site';
---

<section id="opiniones" class="bg-carbon py-20 text-crema md:py-28">
  <div class="container-x">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-arena">Opiniones</p>
      <h2 class="font-display text-4xl text-crema md:text-5xl">Lo que dicen quienes vienen</h2>
      <p class="mt-4 text-crema/70">{site.rating} sobre 5 · {site.ratingFuente}</p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        opiniones.map((o) => (
          <figure class="reveal flex h-full flex-col rounded-2xl bg-carbon-700 p-7 ring-1 ring-crema/10">
            <div class="mb-4 flex gap-1" aria-label={`${o.estrellas} de 5 estrellas`}>
              {Array.from({ length: o.estrellas }).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A86A">
                  <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 font-display text-xl italic leading-relaxed text-crema/90">
              “{o.texto}”
            </blockquote>
            <figcaption class="mt-6 border-t border-crema/10 pt-4">
              <p class="font-semibold text-crema">{o.autor}</p>
              <p class="text-sm text-crema/55">{o.detalle}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="reveal mt-8 text-center text-xs text-crema/40">
      Opiniones de muestra para la demostración. En la web real se conectan reseñas verificadas.
    </p>
  </div>
</section>
