---
// Emblema simple y elegante de Sal Marina: sol sobre el mar.
// Usa currentColor (se adapta al color del header). El sol va en terracota.
interface Props {
  class?: string;
}
const { class: className = 'h-7 w-7' } = Astro.props;
---

<svg viewBox="0 0 40 40" fill="none" aria-hidden="true" class={className}>
  <circle cx="20" cy="20" r="18.3" stroke="currentColor" stroke-width="1.3" />
  <circle cx="20" cy="15" r="2.4" fill="#d96a3f" />
  <path
    d="M9 23 q2.75 -2.6 5.5 0 t5.5 0 t5.5 0 t5.5 0"
    stroke="currentColor"
    stroke-width="1.3"
    stroke-linecap="round"
  />
  <path
    d="M9 27.4 q2.75 -2.6 5.5 0 t5.5 0 t5.5 0 t5.5 0"
    stroke="currentColor"
    stroke-width="1.3"
    stroke-linecap="round"
    opacity="0.55"
  />
</svg>
