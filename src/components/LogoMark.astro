---
// Emblema de Sal Marina: sol con rayos poniéndose sobre el mar, en un roundel.
// El aro y las olas usan currentColor (se adaptan al color del header); el sol va en terracota.
interface Props {
  class?: string;
}
const { class: className = 'h-9 w-9' } = Astro.props;
---

<svg viewBox="0 0 44 44" fill="none" aria-hidden="true" class={className}>
  <!-- aro -->
  <circle cx="22" cy="22" r="20.4" stroke="currentColor" stroke-width="1.1" />

  <!-- rayos del sol -->
  <g stroke="#d96a3f" stroke-width="1.2" stroke-linecap="round">
    <line x1="18.0" y1="15.7" x2="16.5" y2="14.8" />
    <line x1="19.7" y1="14.0" x2="18.8" y2="12.5" />
    <line x1="22.0" y1="13.4" x2="22.0" y2="11.6" />
    <line x1="24.3" y1="14.0" x2="25.2" y2="12.5" />
    <line x1="26.0" y1="15.7" x2="27.5" y2="14.8" />
  </g>

  <!-- sol -->
  <circle cx="22" cy="18" r="3.3" fill="#d96a3f" />

  <!-- mar (olas) -->
  <path
    d="M10 27 q3 -2.4 6 0 t6 0 t6 0 t6 0"
    stroke="currentColor"
    stroke-width="1.2"
    stroke-linecap="round"
  />
  <path
    d="M10 31 q3 -2.4 6 0 t6 0 t6 0 t6 0"
    stroke="currentColor"
    stroke-width="1.2"
    stroke-linecap="round"
    opacity="0.5"
  />
</svg>
