---
import { site } from '../data/site';
import { asset } from '../lib/asset';

// Art-dirección: resaltamos "brasa" en el titular sin dejar de leerlo de los datos.
const palabras = site.titularHero.split(' ');
---

<section id="inicio" class="relative flex min-h-[100svh] w-full flex-col overflow-hidden bg-tinta text-papel">
  <!--
    Fondo del hero. DEMO: foto real (terraza frente al mar al atardecer) + zoom lento sutil.
    CLIENTE REAL: cambia la imagen por una foto suya con el mismo nombre, o usa vídeo:
    descomenta el <video>, pon su .mp4/.webm en /public/assets/img (ver CAMBIAR_DATOS_CLIENTE.md).
  -->
  <!--
  <video class="kenburns absolute inset-0 h-full w-full object-cover" autoplay muted loop playsinline
    poster={asset('/assets/img/hero-terraza-mar.jpg')}>
    <source src={asset('/assets/img/hero.webm')} type="video/webm" />
    <source src={asset('/assets/img/hero.mp4')} type="video/mp4" />
  </video>
  -->
  <img
    src={asset('/assets/img/hero-terraza-mar.jpg')}
    alt="Terraza de Sal Marina a pie de playa, frente al mar"
    class="kenburns absolute inset-0 h-full w-full object-cover"
    fetchpriority="high"
  />

  <!-- Capas de oscurecido: arriba (para el logo del header) y abajo-izquierda (para el texto) -->
  <div class="absolute inset-0 bg-gradient-to-t from-tinta via-tinta/35 to-tinta/70"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-tinta/80 via-tinta/25 to-transparent"></div>

  <!-- Contenido: anclado al tercio inferior (mt-auto) y con margen de seguridad
       bajo el header (pt-24) para no pisarse nunca con el logo -->
  <div class="container-x relative z-10 mt-auto pb-12 pt-24 md:pb-16">
    <h1 class="reveal display max-w-[14ch] text-[clamp(2.9rem,8.5vw,7rem)] leading-[0.9]">
      {
        palabras.map((p) =>
          p.toLowerCase().replace(/[,.]/g, '') === 'brasa' ? (
            <span class="font-hand text-[1.15em] font-bold leading-none text-brasa-400">{p} </span>
          ) : (
            <span>{p} </span>
          )
        )
      }
    </h1>

    <p class="reveal mt-6 max-w-md text-papel/85">{site.subtituloHero}</p>

    <!-- Reserva como línea de carta (no botón genérico) -->
    <a href="#reserva" class="reveal leader group mt-6 max-w-xs text-papel">
      <span class="font-display text-2xl italic">Reservar mesa</span>
      <span class="leader__fill"></span>
      <span class="kicker text-brasa-400">hoy</span>
    </a>

    <!-- Línea de datos clave (integrada, no badges, sin reseñas) -->
    <div class="reveal mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-papel/20 pt-5 text-sm text-papel/75">
      <span>Palma de Mallorca</span>
      <span class="text-papel/30">·</span>
      <span>Desde {site.fundadoEn}</span>
      <span class="text-papel/30">·</span>
      <span>Cocina de mercado</span>
    </div>
  </div>
</section>
