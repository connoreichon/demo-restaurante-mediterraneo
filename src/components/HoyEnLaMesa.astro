---
import { lonja } from '../data/site';
import { asset } from '../lib/asset';
---

<section id="lonja" class="relative scroll-mt-24 overflow-hidden py-20 md:py-28">
  <div class="container-x">
    <!-- Intro -->
    <header class="reveal mb-12 flex flex-col gap-6 md:mb-16 md:flex-row md:items-end md:justify-between">
      <div class="flex items-end gap-5">
        <span class="sec-num text-7xl text-brasa/30 md:text-8xl">I</span>
        <div>
          <p class="kicker text-brasa">Del día</p>
          <h2 class="display mt-2 text-5xl md:text-6xl">Hoy entra por lonja</h2>
        </div>
      </div>
      <p class="nota max-w-xs text-oliva md:text-right">{lonja.nota}</p>
    </header>

    <div class="md:grid md:grid-cols-12 md:gap-12">
      <!-- Imagen del día (descentrada, con sello) -->
      <div class="relative md:col-span-5">
        <figure class="reveal relative mb-10 md:mb-0 md:rotate-[-3deg]">
          <img
            src={asset(lonja.productos[0].imagen)}
            alt={lonja.productos[0].nombre}
            class="aspect-[4/5] w-full object-cover shadow-[0_30px_60px_-30px_rgba(23,19,13,0.55)]"
            loading="lazy"
          />
          <figcaption class="mt-2 font-display text-xl italic text-tinta/70">{lonja.productos[0].nombre}</figcaption>
          <div class="sello absolute -right-3 -top-4 h-24 w-24 rotate-12 bg-papel md:-right-5">
            <span class="px-2"><span class="kicker text-[0.5rem]">recién</span><br /><span class="font-display text-xl not-italic leading-none">de lonja</span></span>
          </div>
        </figure>
      </div>

      <!-- Pizarra del día: 3 productos en formato carta -->
      <ol class="md:col-span-7">
        {
          lonja.productos.map((p, i) => (
            <li class="reveal border-b border-tinta/15 py-7 first:border-t">
              <div class="leader">
                <h3 class="display flex items-baseline gap-3 text-2xl md:text-[1.8rem]">
                  <span class="text-sm text-oro">{String(i + 1).padStart(2, '0')}</span>
                  {p.nombre}
                </h3>
                <span class="leader__fill" />
                <span class="font-display text-xl italic text-brasa">{p.precio === 's/m' ? 's/m' : `${p.precio} €`}</span>
              </div>
              <div class="mt-3 flex flex-col gap-2 pl-9 sm:flex-row sm:items-center sm:gap-6">
                <span class="kicker w-fit border border-tinta/25 px-3 py-1 text-tinta/60">{p.origen}</span>
                <p class="nota text-oliva">{p.preparacion}</p>
              </div>
            </li>
          ))
        }
        <li class="reveal pt-7 text-sm text-tinta/55">
          Y de la carta: arroces a fuego lento, verduras de la huerta a la brasa y postres caseros.
          <span class="block">Opciones vegetarianas y sin gluten · Consúltanos alérgenos.</span>
        </li>
      </ol>
    </div>
  </div>
</section>
