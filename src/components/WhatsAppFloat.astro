---
import { site } from '../data/site';
import WhatsAppIcon from './WhatsAppIcon.astro';
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`;
---

<a
  href={waLink}
  target="_blank"
  rel="noopener"
  aria-label="Reservar por WhatsApp"
  class="group fixed bottom-5 right-5 z-50 inline-flex items-center gap-2.5 rounded-full bg-[#25D366] py-3.5 pl-4 pr-5 text-white shadow-[0_12px_30px_-10px_rgba(37,211,102,0.7)] ring-1 ring-black/5 transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#1faf53] hover:shadow-[0_16px_36px_-10px_rgba(37,211,102,0.75)] md:bottom-7 md:right-7 md:p-3.5 md:pr-3.5"
>
  <WhatsAppIcon class="h-6 w-6 shrink-0 md:h-5 md:w-5" />
  <span class="text-sm font-semibold tracking-tight md:hidden">Reservar</span>
</a>
