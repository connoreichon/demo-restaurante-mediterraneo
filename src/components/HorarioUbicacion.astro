---
import { site } from '../data/site';
---

<section id="horario" class="bg-crema py-20 md:py-28">
  <div class="container-x grid gap-10 lg:grid-cols-2">
    <!-- Horario -->
    <div class="reveal">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-terracota">Horario</p>
      <h2 class="font-display text-4xl text-carbon md:text-5xl">Cuándo abrimos</h2>

      <dl class="mt-8 divide-y divide-carbon/10 rounded-2xl bg-white p-2 shadow-soft ring-1 ring-carbon/5">
        {
          site.horario.map((h) => (
            <div class="flex items-center justify-between gap-4 px-4 py-4">
              <dt class="font-medium text-carbon">{h.dia}</dt>
              <dd class:list={['text-right text-sm', h.cerrado ? 'font-semibold text-terracota' : 'text-carbon/70']}>
                {h.horas}
              </dd>
            </div>
          ))
        }
      </dl>
      <p class="mt-4 text-sm text-carbon/60">{site.avisoHorario}</p>

      <div class="mt-7 rounded-2xl bg-oliva/10 p-5 ring-1 ring-oliva/20">
        <p class="font-display text-2xl text-carbon">¿Reservamos tu mesa?</p>
        <p class="mt-1 text-sm text-carbon/70">Llámanos o escríbenos por WhatsApp, te respondemos al momento.</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href={`tel:${site.telefono.replace(/\s/g, '')}`}
            class="rounded-full bg-carbon px-5 py-2.5 text-sm font-semibold text-crema transition-colors hover:bg-carbon-700"
          >
            {site.telefono}
          </a>
          <a
            href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMensaje)}`}
            target="_blank"
            rel="noopener"
            class="rounded-full border border-carbon/20 px-5 py-2.5 text-sm font-semibold text-carbon transition-colors hover:bg-carbon/5"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- Ubicación + mapa -->
    <div class="reveal">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-terracota">Dónde estamos</p>
      <h2 class="font-display text-4xl text-carbon md:text-5xl">Cómo llegar</h2>

      <p class="mt-6 text-lg text-carbon">{site.direccion}</p>
      <p class="text-carbon/70">{site.ciudad}</p>

      <!-- Mapa: placeholder. Sustituir por el <iframe> real de Google Maps (ver CAMBIAR_DATOS_CLIENTE.md) -->
      <div class="mt-6 overflow-hidden rounded-2xl shadow-soft ring-1 ring-carbon/10">
        {
          site.mapsEmbed ? (
            <iframe
              src={site.mapsEmbed}
              title="Mapa de ubicación"
              width="100%"
              height="320"
              style="border:0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            />
          ) : (
            <a
              href={site.mapsLink}
              target="_blank"
              rel="noopener"
              class="relative grid h-80 place-items-center bg-gradient-to-br from-oliva/25 via-crema-200 to-arena/30"
            >
              <span
                class="pointer-events-none absolute inset-0 opacity-40"
                style="background-image: linear-gradient(rgba(26,26,24,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(26,26,24,.08) 1px, transparent 1px); background-size: 32px 32px;"
              />
              <div class="relative flex flex-col items-center gap-2 text-carbon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#C1440E" stroke-width="1.8">
                  <path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z" />
                  <circle cx="12" cy="10" r="2.5" fill="#C1440E" stroke="none" />
                </svg>
                <span class="font-semibold">Abrir en Google Maps</span>
                <span class="text-sm text-carbon/60">Mapa de demostración</span>
              </div>
            </a>
          )
        }
      </div>

      <a
        href={site.mapsLink}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-terracota hover:text-terracota-400"
      >
        Cómo llegar
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</section>
